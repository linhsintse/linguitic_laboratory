generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // e.g., "file:./dev.db"
}

model Word {
  id        Int              @id @default(autoincrement())
  text      String           @unique
  entries   WorksheetEntry[]
  morphemes WordMorpheme[]
}

model Worksheet {
  id        Int              @id @default(autoincrement())
  name      String?
  createdAt DateTime         @default(now())
  entries   WorksheetEntry[]
}

model WorksheetEntry {
  id          Int       @id @default(autoincrement())
  wordId      Int
  worksheetId Int
  columnIndex Int
  position    Int
  word        Word      @relation(fields: [wordId], references: [id])
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
}

model Morpheme {
  id        Int            @id @default(autoincrement())
  type      String // 'prefix', 'root', 'suffix'
  text      String
  displaytext String
  meaning   String
  origin    String? // e.g., 'OE', 'L', 'G', 'F'
  frequency Int? // 1-100 score
  category  String? // Maps to Category, Semantic Field, or Transformation
  words     WordMorpheme[]

  @@unique([text, meaning])
}

// Explicit Many-to-Many Join Table
model WordMorpheme {
  wordId     Int
  morphemeId Int
  word       Word     @relation(fields: [wordId], references: [id])
  morpheme   Morpheme @relation(fields: [morphemeId], references: [id])

  // The combination of word and morpheme must be unique
  @@id([wordId, morphemeId])
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  username String  @unique
  name     String?
  password String
}
