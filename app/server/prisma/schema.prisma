generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // e.g., "file:./dev.db"
}

model Word {
  id      Int              @id @default(autoincrement())
  text    String           @unique
  entries WorksheetEntry[]
}

model Worksheet {
  id        Int               @id @default(autoincrement())
  name      String?
  createdAt DateTime          @default(now())
  userId    Int
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   WorksheetEntry[]
  columns   WorksheetColumn[]
}

model WorksheetColumn {
  id          Int       @id @default(autoincrement())
  worksheetId Int
  columnIndex Int
  morpheme    String?
  type        String?   @default("root")
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@unique([worksheetId, columnIndex])
}

model WorksheetEntry {
  id          Int       @id @default(autoincrement())
  wordId      Int
  worksheetId Int
  columnIndex Int
  position    Int
  word        Word      @relation(fields: [wordId], references: [id])
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
}

model User {
  id        Int         @id @default(autoincrement())
  email     String      @unique
  username  String      @unique
  firstname String?
  lastname  String?
  role      String?     @default("student")
  password  String
  teacherId Int?
  teacher   User?       @relation("StudentTeacher", fields: [teacherId], references: [id])
  students  User[]      @relation("StudentTeacher")
  worksheets Worksheet[]
}

model KaikkiEtymology {
  id Int @id @default(autoincrement())

  term String
  lang String?
  pos  String? // Part of speech (noun, verb, etc. - highly useful for filtering later)

  template_name String // e.g., 'prefix', 'suffix', 'affix', 'compound', 'inherited'
  morpheme      String // The extracted component (e.g., 'un-', 'state', 'ment')
  morpheme_lang String? // The language code of the component
  position      Int // The argument index to maintain left-to-right morphological order

  // Indexes are critical here since we are not using Foreign Keys for the dictionary data
  @@index([term])
  @@index([morpheme])
  @@index([template_name])
}
