generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // e.g., "file:./dev.db"
}

model Word {
  id        Int              @id @default(autoincrement())
  text      String           @unique
  entries   WorksheetEntry[]
}

model Worksheet {
  id        Int              @id @default(autoincrement())
  name      String?
  createdAt DateTime         @default(now())
  entries   WorksheetEntry[]
  columns   WorksheetColumn[]
}

model WorksheetColumn {
  id          Int       @id @default(autoincrement())
  worksheetId Int
  columnIndex Int
  name        String
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@unique([worksheetId, columnIndex])
}

model WorksheetEntry {
  id          Int       @id @default(autoincrement())
  wordId      Int
  worksheetId Int
  columnIndex Int
  position    Int
  word        Word      @relation(fields: [wordId], references: [id])
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
}



model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  username String  @unique
  name     String?
  password String
}

model Etymology {
  id              Int     @id @default(autoincrement())
  term_id         String
  lang            String?
  term            String?
  reltype         String?
  related_term_id String?
  related_lang    String?
  related_term    String?
  position        Int?
  group_tag       String?
  parent_tag      String?
  parent_position Int?
}
