generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // e.g., "file:./dev.db"
}

model Word {
  id        Int             @id @default(autoincrement())
  text      String          @unique
  entries   WeeklyEntry[]
  morphemes WordMorpheme[]
}

model WeeklyTable {
  id         Int           @id @default(autoincrement())
  weekNumber Int
  year       Int
  entries    WeeklyEntry[]

  // Ensures you never have two tables for the exact same week and year
  @@unique([weekNumber, year]) 
}

model WeeklyEntry {
  id            Int         @id @default(autoincrement())
  wordId        Int
  weeklyTableId Int
  dayOfWeek     Int         // Suggestion: Enforce 0-6 in your TS logic
  position      Int?        // e.g., 1-10 for the word's order that day
  word          Word        @relation(fields: [wordId], references: [id])
  weeklyTable   WeeklyTable @relation(fields: [weeklyTableId], references: [id])
}

model Morpheme {
  id        Int            @id @default(autoincrement())
  type      String         // 'prefix', 'root', 'suffix'
  text      String         
  meaning   String
  origin    String?        // e.g., 'OE', 'L', 'G', 'F'
  frequency Int?           // 1-100 score
  category  String?        // Maps to Category, Semantic Field, or Transformation
  words     WordMorpheme[]

  @@unique([text, meaning])
}

// Explicit Many-to-Many Join Table
model WordMorpheme {
  wordId     Int
  morphemeId Int
  word       Word     @relation(fields: [wordId], references: [id])
  morpheme   Morpheme @relation(fields: [morphemeId], references: [id])

  // The combination of word and morpheme must be unique
  @@id([wordId, morphemeId]) 
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  password String
}